{
  "id": "river",
  "name": "River",
  "description": "Keyword-alignment (\"river\") style: clause keywords (SELECT/FROM/WHERE/JOIN/ON/AND/GROUP BY/...) right-pad their first word to a shared column per statement/subquery scope, with CTE names and subquery content starting at that same column.",
  "version": "1.0.0",
  "schemaVersion": "1.0.0",
  "dialect": "generic",
  "extends": null,
  "source": {
    "type": "manual"
  },
  "style": {
    "layout": {
      "mode": "keywordAlign"
    },
    "casing": {
      "keywords": "upper",
      "functions": "upper",
      "types": "upper",
      "identifiers": "preserve"
    },
    "indentation": {
      "char": "space",
      "size": 2
    },
    "lineWidth": 100,
    "clauses": {
      "forceNewlinePerClause": true,
      "inlineShortStatements": false
    },
    "lists": {
      "onePerLine": false,
      "wrapThresholdItems": 999
    },
    "commas": {
      "style": "trailing",
      "alignAfterComma": false
    },
    "joins": {
      "onClausePlacement": "newLine",
      "multiConditionIndent": 1
    },
    "booleanOperators": {
      "style": "leading",
      "indentContinuation": false
    },
    "ctes": {
      "onePerLine": true,
      "blankLineBetween": false
    },
    "parentheses": {
      "subqueryOpenParenSameLine": true
    },
    "alignment": {
      "aliases": false,
      "assignments": false
    },
    "quoting": {
      "forceQuoteIdentifiers": false,
      "quoteChar": "none"
    },
    "blankLines": {
      "betweenStatements": "collapseToOne",
      "aroundCtes": false
    },
    "statementTerminator": {
      "alwaysAppendSemicolon": true
    }
  }
}
