{
  "id": "river-quoted",
  "name": "River (quoted identifiers)",
  "description": "Same keyword-alignment (\"river\") style as river.json, but every identifier is forced double-quoted — matches a source style where every column/table reference is quoted verbatim.",
  "version": "1.0.0",
  "schemaVersion": "1.0.0",
  "dialect": "generic",
  "extends": null,
  "source": {
    "type": "manual"
  },
  "style": {
    "layout": {
      "mode": "keywordAlign"
    },
    "casing": {
      "keywords": "upper",
      "functions": "upper",
      "types": "upper",
      "identifiers": "preserve"
    },
    "indentation": {
      "char": "space",
      "size": 2
    },
    "lineWidth": 100,
    "clauses": {
      "forceNewlinePerClause": true,
      "inlineShortStatements": false
    },
    "lists": {
      "onePerLine": true,
      "wrapThresholdItems": 1
    },
    "commas": {
      "style": "trailing",
      "alignAfterComma": false
    },
    "joins": {
      "onClausePlacement": "newLine",
      "multiConditionIndent": 1
    },
    "booleanOperators": {
      "style": "leading",
      "indentContinuation": false
    },
    "ctes": {
      "onePerLine": true,
      "blankLineBetween": false
    },
    "parentheses": {
      "subqueryOpenParenSameLine": true
    },
    "alignment": {
      "aliases": false,
      "assignments": false
    },
    "aliasing": {
      "autoAliasBareColumns": true
    },
    "quoting": {
      "forceQuoteIdentifiers": true,
      "quoteChar": "double",
      "quoteAliases": false
    },
    "blankLines": {
      "betweenStatements": "collapseToOne",
      "aroundCtes": false
    },
    "statementTerminator": {
      "alwaysAppendSemicolon": true
    }
  }
}
